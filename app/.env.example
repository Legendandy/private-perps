# Copy this to .env and fill in your values after deploying

# Your deployed Anchor program ID (from `anchor deploy`)
VITE_PROGRAM_ID=REPLACE_WITH_YOUR_DEPLOYED_PROGRAM_ID

# Solana RPC endpoint (devnet for development)
VITE_RPC_URL=https://api.devnet.solana.com

# Your Render backend URL (from Phase 6)
VITE_BACKEND_API_BASE=https://your-stealth-perps-api.onrender.com

# Set to "true" to run in mock mode (no wallet / devnet needed)
# Set to "false" (or remove) for real Arcium integration
VITE_MOCK_ARCIUM=true
